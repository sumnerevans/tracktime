directory: $HOME/.tracktime
reporting:
    fullname: John Doe
    day_worked_min_threshold: 120
    report_statistics: true
    project_rates:
        teaching/tutoring: 50
    customer_rates: {}
    customer_aliases: {}
    customer_addresses: {}
sync:
    enable: true # Based on sync_time: true from original
github:
    access_token: cat /path/to/my/github/access/token/secret|
    username: example
gitlab:
    api_key: cat /path/to/my/gitlab/api/key/secret|
    api_root: https://gitlab.com/api/v4/
sourcehut:
    access_token: cat /path/to/my/sourcehut/access/token|
    api_root: https://todo.sr.ht/api/
    username: ~example
linear:
    default_org: my-org
    api_key: cat /etc/nixos/secrets/linear-api-key|
item_cache_ttl_days: 30
editor: ""
editor_args: []
typst_path: ""
logging:
    min_level: info
    writers:
        - type: file
          format: json
          filename: $XDG_STATE_HOME/tracktime/tracktime.log
          max_size: 10 # megabytes
          max_age: 90 # days
